{
  "name": "perfscope",
  "displayName": "PerfScope",
  "description": "VS Code performance health scanner and optimization guide - analyze extensions, find slowdown causes, and apply safe workspace fixes with one click.",
  "version": "1.0.0",
  "publisher": "Evhye",
  "license": "MIT",
  "icon": "resources/perfscope-128.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/evhye38496-svg/PerfScope.git"
  },
  "bugs": {
    "url": "https://github.com/evhye38496-svg/PerfScope/issues"
  },
  "homepage": "https://github.com/evhye38496-svg/PerfScope#readme",
  "keywords": [
    "performance",
    "optimization",
    "scanner",
    "dashboard",
    "workspace",
    "extensions",
    "audit",
    "speed",
    "startup",
    "health check",
    "score",
    "monitor",
    "clean",
    "boost",
    "fast",
    "memory",
    "analysis",
    "extension manager"
  ],
  "galleryBanner": {
    "color": "#1f6feb",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./out/src/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "onCommand:perfscope.runFullScan",
    "onCommand:perfscope.showDashboard",
    "onCommand:perfscope.quickAudit",
    "onCommand:perfscope.exportReport",
    "onCommand:perfscope.applySafeFixes",
    "onCommand:perfscope.undoLastFix",
    "onCommand:perfscope.purge",
    "onView:perfscope.dashboard"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "perfscope",
          "title": "PerfScope",
          "icon": "resources/perfscope.svg"
        }
      ]
    },
    "views": {
      "perfscope": [
        {
          "type": "webview",
          "id": "perfscope.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "perfscope.runFullScan",
        "title": "PerfScope: Run Full Scan",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.showDashboard",
        "title": "PerfScope: Show Dashboard",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.quickAudit",
        "title": "PerfScope: Quick Extension Audit",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.exportReport",
        "title": "PerfScope: Export Report (Markdown)",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.applySafeFixes",
        "title": "PerfScope: Apply All Safe Fixes",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.undoLastFix",
        "title": "PerfScope: Undo Last Fix",
        "category": "PerfScope"
      },
      {
        "command": "perfscope.purge",
        "title": "PerfScope: Purge & Prepare for Uninstall",
        "category": "PerfScope"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "npm run test:unit",
    "test:unit": "npm run compile && node --test \"out/test/unit/*.test.js\"",
    "test:vscode": "npm run compile && node ./out/test/vscode/runTest.js",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile",
    "package:vsix": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && vsce package --out dist/perfscope-1.0.0.vsix",
    "verify:release": "npm run compile && node scripts/verify-release.js && npm test && npm run test:vscode && npm run package:vsix"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.2",
    "typescript": "^5.9.3"
  }
}
